GEMINI_API_KEY=your_key_here

# Optional: override the model. Defaults to gemini-3.1-flash-lite (audio-capable,
# generous free-tier RPD).
#
# IMPORTANT: SpeakWell sends audio to the model, so the override MUST be an
# audio-capable Gemini model. Use gemini-3.1-flash-lite (default) or
# gemini-2.5-flash. Do NOT use retired/older models like gemini-2.0-flash
# (shut down 2026-06-01) — they will fail.
# GEMINI_MODEL=gemini-2.5-flash
